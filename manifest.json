{
  "manifest_version": 3,
  "name": "LeetDiff",
  "version": "1.0.0",
  "description": "Hides difficulty labels on LeetCode so you can solve problems without bias.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
